{
  "name": "optcg-japan-tracker",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "preinstall": "node scripts/enforce-pnpm.js",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "backfill:images": "tsx scripts/seed/backfill-images.ts",
    "seed:english-names": "tsx scripts/seed/update-english-names.ts",
    "seed:repair-english-names": "tsx scripts/seed/repair-english-names.ts",
    "seed:punk-records": "tsx scripts/seed/punk-records.ts",
    "test:price-ingestion": "node --import tsx scripts/price-ingestion/validate-fixtures.ts",
    "test:db:cards": "bash tests/db/run-card-smoke.sh",
    "scrape": "tsx scripts/scrape/index.ts",
    "scrape:validate": "tsx scripts/scrape/validate-env.ts"
  },
  "dependencies": {
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-dialog": "^1.1.15",
    "@supabase/supabase-js": "^2.49.8",
    "@tanstack/react-query": "^5.80.10",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.3",
    "autoprefixer": "^10.4.27",
    "axios": "1.14.0",
    "cheerio": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lightweight-charts": "^5.0.8",
    "lucide-react": "^0.511.0",
    "next": "^15.3.0",
    "postcss": "^8.5.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/node": "^22.15.17",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "eslint": "^9.25.1",
    "eslint-config-next": "^15.3.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
